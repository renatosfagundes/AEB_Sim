<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="ego_vehicle">
    <static>false</static>
    <pose>0 -1.85 0 0 0 0</pose>

    <!-- Main body (chassis) -->
    <link name="chassis">
      <pose>0 0 0.4 0 0 0</pose>
      <inertial>
        <mass>1500.0</mass>
        <inertia>
          <ixx>500.0</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1500.0</iyy><iyz>0</iyz>
          <izz>1500.0</izz>
        </inertia>
      </inertial>

      <!-- Visual: use hatchback_blue mesh from gazebo_models -->
      <visual name="body_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://hatchback_blue/meshes/hatchback.obj</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>

      <!-- Collision: simplified box -->
      <collision name="body_collision">
        <pose>0 0 0.2 0 0 0</pose>
        <geometry>
          <box>
            <size>4.5 1.8 1.4</size>
          </box>
        </geometry>
      </collision>

      <!-- Sensor specifications (documented here, simulated in perception_node.py)

           77 GHz Radar (primary):
             Range: 0.5-260m, FOV: ±9°, Update: 20 Hz, Noise: σ=0.25m

           Lidar (secondary):
             Range: 0.3-200m, FOV: ±15°, Update: 15 Hz, Noise: σ=0.05m

           Note: Physical ray sensors are disabled for WSL2 performance.
           The perception_node.py simulates both sensors with realistic noise
           and performs radar+lidar fusion using ground-truth odom as input.
      -->

      <!-- IMU sensor for ego acceleration -->
      <sensor name="imu" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
          </linear_acceleration>
        </imu>
        <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
          <ros>
            <namespace>/aeb</namespace>
            <remapping>~/out:=imu</remapping>
          </ros>
          <frame_name>ego_imu</frame_name>
        </plugin>
      </sensor>
    </link>

    <!-- Four wheels -->
    <link name="front_left_wheel">
      <pose>1.4 0.8 0.3 -1.5708 0 0</pose>
      <inertial><mass>15.0</mass>
        <inertia><ixx>0.5</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.5</iyy><iyz>0</iyz><izz>0.9</izz></inertia>
      </inertial>
      <collision name="collision"><geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <surface><friction><ode><mu>0.9</mu><mu2>0.9</mu2></ode></friction></surface>
      </collision>
      <visual name="visual"><geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <link name="front_right_wheel">
      <pose>1.4 -0.8 0.3 -1.5708 0 0</pose>
      <inertial><mass>15.0</mass>
        <inertia><ixx>0.5</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.5</iyy><iyz>0</iyz><izz>0.9</izz></inertia>
      </inertial>
      <collision name="collision"><geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <surface><friction><ode><mu>0.9</mu><mu2>0.9</mu2></ode></friction></surface>
      </collision>
      <visual name="visual"><geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <link name="rear_left_wheel">
      <pose>-1.4 0.8 0.3 -1.5708 0 0</pose>
      <inertial><mass>15.0</mass>
        <inertia><ixx>0.5</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.5</iyy><iyz>0</iyz><izz>0.9</izz></inertia>
      </inertial>
      <collision name="collision"><geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <surface><friction><ode><mu>0.9</mu><mu2>0.9</mu2></ode></friction></surface>
      </collision>
      <visual name="visual"><geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <link name="rear_right_wheel">
      <pose>-1.4 -0.8 0.3 -1.5708 0 0</pose>
      <inertial><mass>15.0</mass>
        <inertia><ixx>0.5</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.5</iyy><iyz>0</iyz><izz>0.9</izz></inertia>
      </inertial>
      <collision name="collision"><geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <surface><friction><ode><mu>0.9</mu><mu2>0.9</mu2></ode></friction></surface>
      </collision>
      <visual name="visual"><geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <!-- Wheel joints -->
    <joint name="front_left_wheel_joint" type="revolute">
      <parent>chassis</parent><child>front_left_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <joint name="front_right_wheel_joint" type="revolute">
      <parent>chassis</parent><child>front_right_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>chassis</parent><child>rear_left_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>chassis</parent><child>rear_right_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>

    <!-- Planar move plugin: allows setting velocity via ROS2 cmd_vel -->
    <plugin name="object_controller" filename="libgazebo_ros_planar_move.so">
      <ros>
        <namespace>/aeb/ego</namespace>
      </ros>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>ego_vehicle</robot_base_frame>
      <odometry_rate>100.0</odometry_rate>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
    </plugin>

  </model>
</sdf>
