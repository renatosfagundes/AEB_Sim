%%{init: {'theme': 'base', 'themeVariables': {'fontSize': '16px', 'fontFamily': 'Arial'}}}%%
graph LR
    subgraph INPUT["Inputs"]
        TDECEL["target_decel<br/>[0, 2, 4, 6] m/s²<br/>from FSM"]
        ADECEL["actual_decel<br/>[m/s²]<br/>from plant"]
    end

    subgraph ERROR["Error Computation"]
        SUM1(("-"))
        ERR["e(k) = target - actual"]
    end

    subgraph PID["PI Controller (Kp=4, Ki=0.05)"]
        P["P = Kp · e(k)"]
        I["I += Ki · e(k) · dt<br/>Anti-windup:<br/>clamp I ∈ [0, 50]"]
        SUM2(("+"))
    end

    subgraph LIMITS["Output Limiting"]
        JERK["Jerk Limiter<br/>|Δu/dt| ≤ 10 m/s³<br/>Rate-limit output change"]
        SAT["Saturation<br/>0 ≤ u ≤ 100%"]
    end

    subgraph OUTPUT["Output"]
        BCMD["brake_cmd [0-100%]"]
    end

    TDECEL --> SUM1
    ADECEL --> SUM1
    SUM1 --> ERR
    ERR --> P --> SUM2
    ERR --> I --> SUM2
    SUM2 --> JERK --> SAT --> BCMD

    style INPUT fill:#e3f2fd,stroke:#1976d2
    style ERROR fill:#fff3e0,stroke:#f57c00
    style PID fill:#e8f5e9,stroke:#388e3c
    style LIMITS fill:#fce4ec,stroke:#c62828
    style OUTPUT fill:#f3e5f5,stroke:#7b1fa2
